# =========================================================================
# UG Bazaar — Monorepo Configuration Template (.env.example)
# =========================================================================
# Copy this file to '.env' in appropriate subdirectories and fill in values.
# Do not commit files containing real keys or secrets to version control.

# -------------------------------------------------------------------------
# BACKEND ENVIRONMENT VARIABLES (Required in ug-bazaar-backend-main/ug-bazaar-backend-main)
# -------------------------------------------------------------------------

# Server Setup
PORT=5000
NODE_ENV=development

# Database Configuration
# Use local connection string: mongodb://127.0.0.1:27017/ugbazaar
# Or MongoDB Atlas connection string (use legacy standard connection format if SRV lookup fails)
MONGO_URI=mongodb://<username>:<password>@cluster0-shard-00-00.xxxx.mongodb.net:27017/ugbazaar?ssl=true&replicaSet=atlas-xxxxx-shard-0&authSource=admin

# JWT Authentication
JWT_SECRET=your_jwt_super_secret_key_change_me
JWT_EXPIRE=30d

# Payments Gateway (Razorpay Integration)
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# SMS & Whatsapp Notification Gateway (Twilio Integration)
TWILIO_ACCOUNT_SID=ACyour_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=+1xxxxxxxxxx

# Media Assets Hosting (Cloudinary Integration)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Store Settings
OWNER_WHATSAPP=+91XXXXXXXXXX
OWNER_NAME="Store Owner Name"
SHOP_NAME="UG Bazaar"
SHOP_LOCATION="Shop Address, City"

# AI Core Configuration (Google Gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Social Authentication (Google OAuth)
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# -------------------------------------------------------------------------
# CUSTOMER FRONTEND ENVIRONMENT VARIABLES (Required in ug-bazaar-customer-frontend)
# -------------------------------------------------------------------------

# Google Sign-In Client ID (Must match the backend Google Client ID)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
